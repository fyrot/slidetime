{
  "name": "slidetime",
  "displayName": "Slidetime",
  "version": "1.0.2",
  "description": "A simple extension that turns text phrases in Google Slides into live timers, countdowns, clocks, and more.",
  "author": "fyrot@outlook.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/chrome": "0.0.258",
    "@types/node": "^20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://docs.google.com/presentation/*"
    ],
    "web_accessible_resources": [
      {
        "resources": ["assets/icon-light.png", "assets/icon-dark.png", "assets/128/light-alt.png", "assets/128/dark-alt.png"],
        "matches": ["<all_urls>"]
      }
    ]
  }
}
